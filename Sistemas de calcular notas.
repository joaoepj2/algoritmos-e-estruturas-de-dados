algoritmo "Sistema_Notas"

   //Declarei um vetor para as notas
var
   notas: vetor[1..5] de real
   i: inteiro
   media: real


funcao calcularMedia: real
var
   soma: real
   j: inteiro
inicio
   soma <- 0

   para j de 1 ate 5 faca
      soma <- soma + notas[j]
   fimpara

   retorne soma / 5
fimfuncao

inicio

// Entrada de dados
para i de 1 ate 5 faca
   escreva("Digite a nota ", i, ": ")
   leia(notas[i])
fimpara

// Processamento dos dados
media <- calcularMedia

// Por fim saída
escreval("Média final: ", media:0:2)

se media >= 7 entao
   escreval("Situação: Aprovado")
senao
   escreval("Situação: Reprovado")
fimse

fimalgoritmo
