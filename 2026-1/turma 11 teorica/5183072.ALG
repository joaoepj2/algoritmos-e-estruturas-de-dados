algoritmo "5183072"

var
   numeros: vetor[1..6] de inteiro
   i: inteiro
   pares, impares: inteiro

procedimento contarParesImpares()
var
   j: inteiro
inicio
   pares <- 0
   impares <- 0

   para j de 1 ate 6 faca
      se numeros[j] mod 2 = 0 entao
         pares <- pares + 1
      senao
         impares <- impares + 1
      fimse
   fimpara
fimprocedimento

inicio
   escreval("=== Verificador de Pares e ═mpares ===")
   escreval("Digite 6 n·meros inteiros:")

   para i de 1 ate 6 faca
      escreva("N·mero ", i, ": ")
      leia(numeros[i])
   fimpara

   contarParesImpares()

   escreval("Quantidade de n·meros pares: ", pares)
   escreval("Quantidade de n·meros Ēmpares: ", impares)

fimalgoritmo