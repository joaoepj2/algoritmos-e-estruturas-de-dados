Algoritmo "soma_de_precos"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 03/05/2026
Var
   // Seçăo de Declaraçőes das variáveis
   precos: vetor[1..5] de real
   i: inteiro
   total: real
procedimento mostrarResultado(valor: real)
inicio
   escreval ("o valor total das compras foi: R$ ", valor)
fimprocedimento

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   total <- 0
   escreval ("-----------Vamos somar os precos-----------")
   escreval("Digite o preco de 5 produtos:")

   para i de 1 ate 5 faca
      escreva("Produto ", i, ": R$ ")
      leia(precos[i])

      total <- total + precos[i]
   fimpara

   mostrarResultado(total)
   escreval ("-------------------------------------------")

Fimalgoritmo